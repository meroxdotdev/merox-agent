# Copy this to .env and fill in your values
# .env is loaded automatically by config.py — no need to source it manually

# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ─────────────────────────────────────────────────────────────────────
SERVER_NAME=my-server          # hostname shown in agent context
SERVER_TS_IP=100.x.x.x         # Tailscale IP (for reference in prompts)

# ── Repos ──────────────────────────────────────────────────────────────────────
INFRA_REPO=/srv/kubernetes/infrastructure
WEBSITE_REPO=/srv/merox

# ── Optional ───────────────────────────────────────────────────────────────────
# AGENT_MODEL=claude-opus-4-6
# AGENT_MAX_TOKENS=4096
# DOCKER_COMPOSE_DIR=/srv/docker
# MEDIA_COMPOSE_FILE=/srv/kubernetes/docker-compose.yml
