# Merox Agent — server configuration
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server identity ───────────────────────────────────────────────────────────
SERVER_NAME=my-server               # hostname shown in agent context
SERVER_TS_IP=100.x.x.x             # tailscale ip -4

# ── Infrastructure repos ──────────────────────────────────────────────────────
INFRA_REPO=/srv/kubernetes/infrastructure
WEBSITE_REPO=/srv/mywebsite
DOCKER_COMPOSE_DIR=/srv/docker

# ── Claude model ──────────────────────────────────────────────────────────────
# claude-opus-4-6   — best quality (default)
# claude-sonnet-4-6 — faster, lower cost
AGENT_MODEL=claude-opus-4-6
AGENT_MAX_TOKENS=8096
AGENT_PORT=8765

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# Create a bot via @BotFather, get your user ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ── Client only (set on your laptop, not the server) ─────────────────────────
# AGENT_SERVER_URL=http://100.x.x.x:8765
