# Merox Agent — server configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Server identity ────────────────────────────────────────────────────────────
SERVER_NAME=cloud                      # hostname shown in agent context
SERVER_TS_IP=100.x.x.x                 # Tailscale IP of this server

# ── Infrastructure repos ───────────────────────────────────────────────────────
INFRA_REPO=/srv/kubernetes/infrastructure
WEBSITE_REPO=/srv/merox

# ── Telegram bot (get token from @BotFather, user ID from @userinfobot) ────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ── Optional overrides ─────────────────────────────────────────────────────────
# AGENT_MODEL=claude-opus-4-6
# AGENT_PORT=8765
# DOCKER_COMPOSE_DIR=/srv/docker
# MEDIA_COMPOSE_FILE=/srv/kubernetes/docker-compose.yml

# ── Client only (set on your laptop, not on the server) ───────────────────────
# AGENT_SERVER_URL=http://100.x.x.x:8765
